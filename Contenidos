void ejecutarOpcion(
    int opcion,
    int vCodigoMarca[],
    string vNombreMarca[],
    int vCodigoProducto[],
    string vNombreProducto[],
    float vPrecioVenta[],
    float vPrecioCompra[],
    int vStock[],
    int vCodigoMarcaProducto[],
    string vCodigoFP[],
    string vNombreFP[],
    int vPorcentajeFP[]
)
{
    switch(opcion)
    {
    case 1:
        system("cls");
        cargarMarcas(vCodigoMarca,
                     vNombreMarca);
        break;
    case 2:
        system("cls");

        cargarProductos(
            vCodigoProducto,
            vNombreProducto,
            vPrecioVenta,
            vPrecioCompra,
            vStock,
            vCodigoMarcaProducto,
            vCodigoMarca,
            vNombreMarca
        );

        break;
    case 3:
    system("cls");

    cargarFormasPago(
        vCodigoFP,
        vNombreFP,
        vPorcentajeFP
    );

    break;
    case 4:
        system("cls");
        cout << "Acá hay que llamar a la Función encargada de ingresar las Ventas..." << endl;
        break;
    case 5:
        system("cls");
        menuReportes();
        break;
    case 22:
        system("cls");
        cout << "Acá hay que llamar a la Función encargada de mostrar los Créditos del Sistema..." << endl;
        break;
    case 0:
        cout << "Good Bye. Lord Vader!" << endl;
        break;
    default:
        cout << "Opción ingresada no es válida." << endl;
    }
}


