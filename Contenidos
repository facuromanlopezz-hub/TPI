///Lote 1
void cargarMarcas(int vCodigoMarca[],
                  string vNombreMarca[])
{
    const int TAM = 10;


    for(int i = 0; i < TAM; i++)
    {
        cout << endl;
        cout << "Marca " << i + 1 << endl;

        vCodigoMarca[i] = pedirCodigoMarca();

        while(buscarMarca(vCodigoMarca, i, vCodigoMarca[i]) != -1)
        {
            cout << "Error. Codigo repetido." << endl;

            vCodigoMarca[i] = pedirCodigoMarca();
        }

        cin.ignore();

        cout << "Ingrese nombre de la marca: ";
        getline(cin, vNombreMarca[i]);

        while(vNombreMarca[i] == "")
        {
            cout << "Error. Debe ingresar un nombre." << endl;
            cout << "Ingrese nuevamente: ";
            getline(cin, vNombreMarca[i]);
        }
    }
    cout << endl;
    cout << "Marcas cargadas:" << endl;

    for(int i = 0; i < TAM; i++)
    {
        cout << vCodigoMarca[i]
             << " - "
             << vNombreMarca[i]
             << endl;
    }
}


int pedirCodigoMarca()
{
    int codigo;

    cout << "Ingrese codigo de marca (1 a 10):  ";
    cin >> codigo;

    while(codigo < 1 || codigo > 10)
    {
        cout << "Error Codigo invalido." << endl;
        cout << "Ingrese el codigo otra vez: ";
        cin >> codigo;
    }

    return codigo;

}

int pedirCodigoProducto()
{
    int codigo;

    cout << "Ingrese codigo de producto: ";
    cin >> codigo;

    while(codigo < 100 || codigo > 999)
    {
        cout << "Error. Debe tener 3 digitos." << endl;
        cout << "Ingrese nuevamente: ";
        cin >> codigo;
    }

    return codigo;
}

int buscarMarca(int vCodigoMarca[], int cantidad, int codigo)
{
    for(int i = 0; i < cantidad; i++)
    {
        if(vCodigoMarca[i] == codigo)
        {
            return i;
        }
    }

    return -1;
}

int buscarProducto(int vCodigoProducto[], int cantidad, int codigo)
{
    for(int i = 0; i < cantidad; i++)
    {
        if(vCodigoProducto[i] == codigo)
        {
            return i;
        }
    }

    return -1;
}

void cargarProductos(
    int vCodigoProducto[],
    string vNombreProducto[],
    float vPrecioVenta[],
    float vPrecioCompra[],
    int vStock[],
    int vCodigoMarcaProducto[],
    int vCodigoMarca[],
    string vNombreMarca[]
)
{
    const int TAM_PRODUCTOS = 20;
    const int TAM_MARCAS = 10;

    if(vCodigoMarca[0] == 0)
    {
        cout << "Error. Primero debe cargar el lote de marcas." << endl;

        limpiarProductos(
            vCodigoProducto,
            vNombreProducto,
            vPrecioVenta,
            vPrecioCompra,
            vStock,
            vCodigoMarcaProducto
        );

        return;
    }

    for(int i = 0; i < TAM_PRODUCTOS; i++)
    {
        cout << endl;
        cout << "Producto " << i + 1 << endl;

        /// Código de producto
        vCodigoProducto[i] = pedirCodigoProducto();

        if(buscarProducto(vCodigoProducto, i, vCodigoProducto[i]) != -1)
        {
            cout << "Error. Codigo de producto repetido." << endl;

            limpiarProductos(
                vCodigoProducto,
                vNombreProducto,
                vPrecioVenta,
                vPrecioCompra,
                vStock,
                vCodigoMarcaProducto
            );

            return;
        }

        /// Nombre
        cin.ignore();

        cout << "Ingrese nombre del producto: ";
        getline(cin, vNombreProducto[i]);

        if(vNombreProducto[i] == "")
        {
            cout << "Error. Debe ingresar un nombre." << endl;

            limpiarProductos(
                vCodigoProducto,
                vNombreProducto,
                vPrecioVenta,
                vPrecioCompra,
                vStock,
                vCodigoMarcaProducto
            );

            return;
        }

        /// Precio de venta
        cout << "Ingrese precio de venta: ";
        cin >> vPrecioVenta[i];

        if(vPrecioVenta[i] == 0)
        {
            cout << "Error. El precio no puede ser 0." << endl;

            limpiarProductos(
                vCodigoProducto,
                vNombreProducto,
                vPrecioVenta,
                vPrecioCompra,
                vStock,
                vCodigoMarcaProducto
            );

            return;
        }

        /// Precio de compra
        cout << "Ingrese precio de compra: ";
        cin >> vPrecioCompra[i];

        if(vPrecioCompra[i] == 0)
        {
            cout << "Error. El precio no puede ser 0." << endl;

            limpiarProductos(
                vCodigoProducto,
                vNombreProducto,
                vPrecioVenta,
                vPrecioCompra,
                vStock,
                vCodigoMarcaProducto
            );

            return;
        }

        /// Stock
        cout << "Ingrese stock: ";
        cin >> vStock[i];

        if(vStock[i] == 0)
        {
            cout << "Error. El stock no puede ser 0." << endl;

            limpiarProductos(
                vCodigoProducto,
                vNombreProducto,
                vPrecioVenta,
                vPrecioCompra,
                vStock,
                vCodigoMarcaProducto
            );

            return;
        }

        /// Código de marca
        cout << "Ingrese codigo de marca: ";
        cin >> vCodigoMarcaProducto[i];

        if(buscarMarca(vCodigoMarca, TAM_MARCAS, vCodigoMarcaProducto[i]) == -1)
        {
            cout << "Codigo de marca no encontrado en el lote de marcas." << endl;

            limpiarProductos(
                vCodigoProducto,
                vNombreProducto,
                vPrecioVenta,
                vPrecioCompra,
                vStock,
                vCodigoMarcaProducto
            );

            return;
        }
    }

    cout << endl;
    cout << "Lote de productos cargado correctamente." << endl;
}


void limpiarProductos(
    int vCodigoProducto[],
    string vNombreProducto[],
    float vPrecioVenta[],
    float vPrecioCompra[],
    int vStock[],
    int vCodigoMarcaProducto[]
)
{
    const int TAM_PRODUCTOS = 20;

    for(int i = 0; i < TAM_PRODUCTOS; i++)
    {
        vCodigoProducto[i] = 0;
        vNombreProducto[i] = "";
        vPrecioVenta[i] = 0;
        vPrecioCompra[i] = 0;
        vStock[i] = 0;
        vCodigoMarcaProducto[i] = 0;
    }
}


///lote 3
int buscarFormaPago(string vCodigoFP[], int cantidad, string codigo)
{
    for(int i = 0; i < cantidad; i++)
    {
        if(vCodigoFP[i] == codigo)
        {
            return i;
        }
    }

    return -1;
}
void cargarFormasPago(
    string vCodigoFP[],
    string vNombreFP[],
    int vPorcentajeFP[]
)
{
    const int TAM_FP = 5;

    for(int i = 0; i < TAM_FP; i++)
    {
        cout << endl;
        cout << "Forma de Pago " << i + 1 << endl;

        cout << "Ingrese codigo (EF, MP, TR, TC o CT): ";
        cin >> vCodigoFP[i];

        while(
            vCodigoFP[i] != "EF" &&
            vCodigoFP[i] != "MP" &&
            vCodigoFP[i] != "TR" &&
            vCodigoFP[i] != "TC" &&
            vCodigoFP[i] != "CT"
        )
        {
            cout << "Codigo invalido." << endl;
            cout << "Ingrese nuevamente: ";
            cin >> vCodigoFP[i];
        }

        if(buscarFormaPago(vCodigoFP, i, vCodigoFP[i]) != -1)
        {
            cout << "Error, el Codigo esta repetido." << endl;
            return;
        }

        cin.ignore();

        cout << "Ingrese nombre de la forma de pago: ";
        getline(cin, vNombreFP[i]);

        if(vNombreFP[i] == "")
        {
            cout << "Error. Debe ingresar un nombre." << endl;
            return;
        }

        cout << "Ingrese porcentaje: ";
        cin >> vPorcentajeFP[i];
    }

    cout << endl;
    cout << "formas de pago cargadas:" << endl;

    for(int i = 0; i < TAM_FP; i++)
    {
        cout << vCodigoFP[i]
             << " -- "
             << vNombreFP[i]
             << " - "
             << vPorcentajeFP[i]
             << endl;
    }

}



