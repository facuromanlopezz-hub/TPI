///Lote 1
void cargarMarcas()
{
    const int TAM = 10;

    int vCodigoMarca[TAM];
    string vNombreMarca[TAM];

    for(int i = 0; i < TAM; i++)
    {
        cout << endl;
        cout << "Marca " << i + 1 << endl;

        vCodigoMarca[i] = pedirCodigoMarca();

        cout << "Ingrese nombre de la marca: ";
        cin >> vNombreMarca[i];
    }
    cout << endl;
cout << "Marcas Cargadas hasta a hora" << endl;

for(int i = 0; i < TAM; i++)
{
    cout << vCodigoMarca[i]
         << " - "
         << vNombreMarca[i]
         << endl;
}
}
int pedirCodigoMarca()
{
    int codigo;

    cout << "Ingrese codigo de marca (1 a 10):  ";
    cin >> codigo;

    while(codigo < 1 || codigo > 10)
    {
        cout << "Error Codigo invalido." << endl;
        cout << "Ingrese el codigo otra vez: ";
        cin >> codigo;
    }

    return codigo;
}


